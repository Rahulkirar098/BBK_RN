# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
else
  use_frameworks! :linkage => :static
end

target 'BookBySeat' do
  config = use_native_modules!

  # Add these explicitly
  pod 'SDWebImage', :modular_headers => true
  pod 'SDWebImageWebPCoder', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # React Native Firebase recommends static frameworks
  $RNFirebaseAsStaticFramework = true

  # Enable debug symbols for Hermes framework
  $RN_HERMES_DEBUG_SYMBOLS = true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix glog and nanopb modular headers issue
    installer.pods_project.targets.each do |target|
      if target.name == 'glog'
        target.build_configurations.each do |config|
          config.build_settings['MODULEMAP_FILE'] = ''
          config.build_settings['DEFINES_MODULE'] = 'NO'
        end
      end
      if target.name == 'nanopb'
        target.build_configurations.each do |config|
          config.build_settings['MODULEMAP_FILE'] = ''
          config.build_settings['DEFINES_MODULE'] = 'NO'
        end
      end
      # Enable debug symbols for Hermes framework
      if target.name.start_with?('hermes')
        target.build_configurations.each do |config|
          config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
          config.build_settings['COPY_PHASE_STRIP'] = 'NO'
          config.build_settings['DEPLOYMENT_POSTPROCESSING'] = 'NO'
          config.build_settings['ENABLE_BITCODE'] = 'NO'
          config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
        end
      end

      # Fix SDWebImage modular headers for Xcode 26+
      if ['SDWebImage', 'SDWebImageWebPCoder'].include?(target.name)
      target.build_configurations.each do |config|
        config.build_settings['DEFINES_MODULE'] = 'YES'
        config.build_settings['SWIFT_COMPILATION_MODE'] = 'wholemodule'
        end
      end
    end

    # Fix fmt 11.0.2 consteval compilation error with Xcode 26.4+
    fmt_base = File.join(installer.sandbox.pod_dir('fmt'), 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(/^#\s*define FMT_USE_CONSTEVAL 1$/, '# define FMT_USE_CONSTEVAL 0')
      if patched != content
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
      end
    end

    # Add GoogleService-Info.plist to app bundle via script phase
    app_target = installer.pods_project.targets.find { |target| target.name == 'BookBySeat' }
    if app_target
      script_phase = app_target.new_shell_script_build_phase('Copy GoogleService-Info.plist')
      script_phase.shell_script = <<-EOS
        cp "${SRCROOT}/GoogleService-Info.plist" "${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.app/"
      EOS
    end
  end
end
